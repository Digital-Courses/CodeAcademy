# ============================================
# Code Academy - Variables de Entorno (PLANTILLA)
# ============================================
# Copia este archivo como .env y llena los valores
# cp .env.example .env

# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DB_NAME=digital_store
DB_USER=digital_user
DB_PASSWORD=digital_pass
DB_HOST=db
DB_PORT=5432

# CORS - Orígenes permitidos del frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
